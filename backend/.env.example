# ============================================================
#  TurnoSalud — Backend — Plantilla de Variables de Entorno
#  Copiá este archivo como ".env" y completá los valores
#  NUNCA commitees el archivo .env real al repositorio
# ============================================================

NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_NAME=turnosalud
DB_USER=root
DB_PASSWORD=Matias1234!

JWT_SECRET=GENERAR_CON_node_-e_require_crypto_randomBytes_64_toString_hex

# URL del frontend (usada en back_urls de MP y links de email)
APP_URL=http://localhost:5173
# URL del backend  (usada en notification_url de MP para webhooks)
API_URL=http://localhost:3001
# Alias para CORS (puede ser igual a APP_URL)
APP_DOMAIN=http://localhost:5173

# ─── Email (Nodemailer) ──────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=TU_EMAIL@gmail.com
MAIL_PASS=TU_APP_PASSWORD_16_CHARS
MAIL_FROM="TurnoSalud" <noreply@turnosalud.com>

# ─── WhatsApp — Twilio ───────────────────────────────────────
# En modo SaaS, estas credenciales se cargan preferentemente desde Admin → Integraciones
# y se guardan en base de datos (configuración global de plataforma).
# Estas variables quedan como fallback/arranque inicial y para entornos sin panel admin.
# 1. Creá una cuenta en https://www.twilio.com
# 2. Activá el Sandbox de WhatsApp en Twilio Console → Messaging → Try it out → Send a WhatsApp message
# 3. Cada paciente debe enviar el mensaje JOIN al número sandbox para activarlo (solo en dev)
# 4. En producción: aprobació Meta Business + número propio en Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox: whatsapp:+14155238886
# Producción: whatsapp:+TU_NUMERO_APROBADO
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── MercadoPago — Checkout Pro (SaaS multi-tenant) ─────────
# Cada profesional conecta SU PROPIA cuenta via OAuth desde /profesional/pagos-config.
#
# MP_CLIENT_ID / MP_CLIENT_SECRET: credenciales de tu APP en el panel de desarrolladores de MP.
#   • Obtener en: https://www.mercadopago.com.ar/developers/panel/app → Crear/Editar app
#   • Configurar Redirect URI: ${API_URL}/api/mp/oauth/callback
MP_CLIENT_ID=
MP_CLIENT_SECRET=
#
# MP_PLATFORM_ACCESS_TOKEN: token de la cuenta PLATAFORMA de MP.
#   • Requerido para procesar webhooks de MP de forma segura en este backend.
#   • Obtener en: https://www.mercadopago.com.ar/developers/panel/app
# MP_PLATFORM_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
#
# MP_WEBHOOK_SECRET: clave secreta para validar la firma HMAC de los webhooks de MP.
#   • Obtener en: https://www.mercadopago.com.ar/developers/panel/webhooks
#   • Si no está configurado, la validación se omite (SOLO aceptable en desarrollo local).
# MP_WEBHOOK_SECRET=TU_CLAVE_SECRETA_WEBHOOK_MP

# ─── Stripe Connect OAuth (SaaS multi-tenant) ────────────────
# Cada profesional conecta SU PROPIA cuenta via OAuth desde /profesional/pagos-config.
#
# STRIPE_CLIENT_ID: ID de la aplicación Connect (empieza con ca_)
#   • Obtener en: https://dashboard.stripe.com/settings/connect → Overview
#   • Configurar Redirect URI: ${API_URL}/api/stripe/oauth/callback
STRIPE_CLIENT_ID=
#
# STRIPE_SECRET_KEY: clave secreta de la cuenta PLATAFORMA (sk_live_... ó sk_test_...)
#   • Obtener en: https://dashboard.stripe.com/apikeys
#   • Se usa como Authorization Bearer para intercambiar el authorization_code por access_token
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET: secreto del endpoint webhook (whsec_...)
#   • Obtener en: https://dashboard.stripe.com/webhooks
#   • Se usa para validar la firma stripe-signature en POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

