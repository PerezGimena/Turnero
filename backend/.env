# ============================================================
#  TurnoSalud — Backend — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Base de datos MySQL ───────────────────────────────────────
# Asegurate de que la BD "turnosalud" exista antes de iniciar.
# Créala ejecutando: mysql -u root -p < backend/database/scripts/setup.sql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=turnosalud
DB_USER=root
DB_PASSWORD=root

# ── JWT ───────────────────────────────────────────────────────
# Cambiá este valor por una cadena larga y aleatoria en producción.
# Generá uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=turnosalud_jwt_secret_cambia_esto_en_produccion_abc123xyz789

# ── CORS ──────────────────────────────────────────────────────
# Dominio(s) del frontend que pueden consumir la API.
# En desarrollo: http://localhost:5173 (Vite por defecto)
APP_DOMAIN=http://localhost:5173

# ── Email (Nodemailer) ────────────────────────────────────────
# Opción A — Gmail con App Password (recomendado para desarrollo)
#   1. Activar 2FA en tu cuenta Gmail
#   2. Ir a: Cuenta Google → Seguridad → Contraseñas de aplicaciones
#   3. Generar una contraseña para "Correo"
#   4. Pegar la contraseña de 16 caracteres en MAIL_PASS
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_email@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM="TurnoSalud" <noreply@turnosalud.com>

# Opción B — Mailtrap (para pruebas locales sin enviar emails reales)
# Crear cuenta gratuita en https://mailtrap.io → Inboxes → SMTP Settings
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USER=tu_usuario_mailtrap
# MAIL_PASS=tu_password_mailtrap
# MAIL_FROM="TurnoSalud Test" <test@turnosalud.com>

# ── Integraciones de pago (opcional) ─────────────────────────
# MercadoPago — Obtené tus credenciales en: https://www.mercadopago.com.ar/developers
# MP_ACCESS_TOKEN=APP_USR-...

# Stripe — Obtené tus credenciales en: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
